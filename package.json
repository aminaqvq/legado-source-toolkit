{
  "name": "legado-source-toolkit",
  "version": "1.5.0-rc.1",
  "description": "A local toolkit for cleaning, validating, classifying, and deduplicating Legado (开源阅读) book source JSON exports",
  "type": "module",
  "bin": {
    "ls-tk": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ web/",
    "web:typecheck": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['dist','dist-web','coverage','uploads'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}));const {globSync}=require('fs');try{const dirs=fs.readdirSync('.').filter(d=>d.startsWith('output')&&fs.statSync(d).isDirectory());dirs.forEach(d=>fs.rmSync(d,{recursive:true,force:true}))}catch(e){}\"",
    "inspect": "tsx src/cli.ts inspect samples/sample.json",
    "process:offline": "tsx src/cli.ts process samples/sample.json --out output-offline --no-online --dedupe conservative --group-mode category-first --name-mode loose",
    "gui": "tsx src/server/app.ts",
    "web:dev": "vite --host 127.0.0.1 --port 5173",
    "web:build": "vite build",
    "web:preview": "vite preview --host 127.0.0.1 --port 5173",
    "verify": "pnpm typecheck && pnpm web:typecheck && pnpm lint && pnpm build && pnpm web:build && pnpm test"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^8.0.2",
    "cheerio": "^1.2.0",
    "commander": "^12.1.0",
    "fastify": "^5.1.0",
    "fs-extra": "^11.2.0",
    "jsonpath-plus": "^10.4.0",
    "p-limit": "^5.0.0",
    "picocolors": "^1.1.1",
    "xmldom": "^0.6.0",
    "xpath": "^0.0.34",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/xmldom": "^0.1.34",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.14.0",
    "prettier": "^3.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "files": [
    "dist/",
    "dist-web/",
    "src/",
    "web/",
    "tests/",
    "docs/",
    "samples/",
    "scripts/",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "tsconfig.web.json",
    "vitest.config.ts",
    "vite.config.ts",
    "eslint.config.js",
    "README.md"
  ]
}
